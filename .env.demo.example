# HealthOps demo environment.
# Copy to .env.demo for local demo overrides:
#   cp .env.demo.example .env.demo

HEALTHOPS_PORT=18080
MONGODB_PORT=27018
MYSQL_PORT=13306
DEMO_API_PORT=19100
DEMO_LINUX_SSH_PORT_1=12222
DEMO_LINUX_SSH_PORT_2=12223

# Demo-only admin bootstrap. Change this if your machine is shared.
HEALTHOPS_DEMO_ADMIN_PASSWORD=healthops-demo-admin
HEALTHOPS_BOOTSTRAP_ADMIN_RESET=true

MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_USER=healthops
MYSQL_PASSWORD=healthops123

# Optional AI model default used by scripts/demo-configure-ai.sh.
# Provide the API key as a one-time shell variable or configure it in the UI.
OPENROUTER_MODEL=openai/gpt-4o-mini
