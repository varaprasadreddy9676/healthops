# Server
HEALTHOPS_PORT=8080

# Database
STORAGE_BACKEND=mongo
MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=healthops
MONGODB_COLLECTION_PREFIX=healthops

# Admin bootstrap
HEALTHOPS_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
HEALTHOPS_BOOTSTRAP_ADMIN_EMAIL=admin@healthops.local
HEALTHOPS_BOOTSTRAP_ADMIN_RESET=false
