# Server
SERVER_ADDR=:8080
HEALTHOPS_PORT=8080
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10

# Database
STATE_PATH=data/state.json
MONGODB_URI=mongodb://localhost:27017
MONGODB_PORT=27017
MONGODB_DATABASE=healthops
MONGODB_COLLECTION_PREFIX=healthops

# Auth
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
HEALTHOPS_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
HEALTHOPS_BOOTSTRAP_ADMIN_EMAIL=admin@healthops.local
HEALTHOPS_BOOTSTRAP_ADMIN_RESET=false

# Scheduler
CHECK_INTERVAL_SECONDS=60
WORKERS=8
RETENTION_DAYS=7

# Security
ALLOW_COMMAND_CHECKS=false
