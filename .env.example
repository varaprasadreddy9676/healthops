# HealthOps Environment Configuration
# ==============================================================================
# Copy this file to .env and customize for your deployment.
# This file is automatically loaded by docker-compose.
#
# PRODUCTION: Set HEALTHOPS_BOOTSTRAP_ADMIN_PASSWORD before first run
# DEMO: Run with compose.demo.yaml using default demo credentials
# ==============================================================================

# =============================================================================
# REQUIRED FOR PRODUCTION - Strong admin password on first startup
# =============================================================================
# Must be set to a strong password before running 'docker compose up' for the
# first time. After the admin user is created in MongoDB, this can be left blank.
# Minimum 12 characters recommended.
HEALTHOPS_BOOTSTRAP_ADMIN_PASSWORD=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port to bind HealthOps dashboard to (default: 8080)
# Change to 18080 if running demo alongside production on same host
HEALTHOPS_PORT=8080

# Bind address for the dashboard
# Use 0.0.0.0 to accept connections from all interfaces.
# Use 127.0.0.1 behind a local reverse proxy or for laptop-only access.
HEALTHOPS_BIND=0.0.0.0

# Public-facing URL for email notification links
# Example: https://healthops.yourcompany.com
# Leave blank if email notifications are disabled or use http://localhost:PORT for local testing
HEALTHOPS_PUBLIC_URL=

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MongoDB URI for persistence (all checks, incidents, results, AI queue)
MONGODB_URI=mongodb://mongo:27017

# MongoDB database and collection naming
MONGODB_DATABASE=healthops
MONGODB_COLLECTION_PREFIX=healthops

# =============================================================================
# ADMIN USER BOOTSTRAP (first startup only)
# =============================================================================

# Admin user email address (used for password resets, notifications)
HEALTHOPS_BOOTSTRAP_ADMIN_EMAIL=admin@healthops.local

# Reset admin password on each startup (set to 'true' for demo, 'false' for production)
# WARNING: Setting this to 'true' in production will reset the admin password every restart
HEALTHOPS_BOOTSTRAP_ADMIN_RESET=false

# =============================================================================
# OPTIONAL - EMAIL NOTIFICATIONS
# =============================================================================

# SMTP password for email notification channels that use smtpPassEnv=HEALTHOPS_SMTP_PASS.
# SMTP host, port, username, sender, and recipients are configured per channel in the UI/API.
HEALTHOPS_SMTP_PASS=

# =============================================================================
# OPTIONAL - EXTERNAL MYSQL MONITORING
# =============================================================================

# DSN for external MySQL instances you want to monitor
# Format: username:password@tcp(host:port)/database?timeout=3s&readTimeout=5s&writeTimeout=5s
# Example: healthops:password@tcp(db.prod.example.com:3306)/app?timeout=3s
MYSQL_DSN=

# =============================================================================
# DEMO ENVIRONMENT ONLY (compose.demo.yaml)
# =============================================================================

# Demo admin credentials
HEALTHOPS_DEMO_ADMIN_PASSWORD=healthops-demo-admin

# Demo MySQL database (internal to docker-compose)
MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_USER=healthops
MYSQL_PASSWORD=healthops123
MYSQL_PORT=13306

# Demo SSH server ports (mapped to localhost)
DEMO_LINUX_SSH_PORT_1=12222
DEMO_LINUX_SSH_PORT_2=12223

# Demo API port
DEMO_API_PORT=19100
