{
  "server": {
    "addr": ":8080",
    "readTimeoutSeconds": 10,
    "writeTimeoutSeconds": 10,
    "idleTimeoutSeconds": 60
  },
  "retentionDays": 7,
  "checkIntervalSeconds": 30,
  "workers": 8,
  "allowCommandChecks": true,
  "checks": [
    {
      "id": "self-health",
      "name": "HealthOps API",
      "type": "api",
      "server": "healthmon",
      "application": "healthops",
      "target": "http://localhost:8080/healthz",
      "expectedStatus": 200,
      "expectedContains": "ok",
      "timeoutSeconds": 5,
      "warningThresholdMs": 500,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["api", "self", "critical"]
    },
    {
      "id": "mongo-tcp",
      "name": "MongoDB Connection",
      "type": "tcp",
      "server": "healthmon",
      "application": "mongodb",
      "host": "mongo",
      "port": 27017,
      "timeoutSeconds": 5,
      "warningThresholdMs": 200,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["tcp", "database", "critical"]
    },
    {
      "id": "mysql-tcp",
      "name": "MySQL Connection",
      "type": "tcp",
      "server": "healthmon",
      "application": "mysql",
      "host": "mysql",
      "port": 3306,
      "timeoutSeconds": 5,
      "warningThresholdMs": 200,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["tcp", "database"]
    },
    {
      "id": "mysql-health",
      "name": "MySQL Database Health",
      "type": "mysql",
      "server": "healthmon",
      "application": "mysql",
      "timeoutSeconds": 10,
      "intervalSeconds": 30,
      "retryCount": 1,
      "retryDelaySeconds": 5,
      "cooldownSeconds": 60,
      "enabled": true,
      "tags": ["mysql", "database", "critical"],
      "mysql": {
        "dsnEnv": "MYSQL_DSN",
        "connectTimeoutSeconds": 3,
        "queryTimeoutSeconds": 5,
        "processlistLimit": 50,
        "statementLimit": 20,
        "hostUserLimit": 20
      }
    },
    {
      "id": "healthmon-process",
      "name": "HealthMon Process",
      "type": "process",
      "server": "healthmon",
      "application": "healthops",
      "target": "healthmon",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "self"]
    },
    {
      "id": "disk-space",
      "name": "Disk Space Check",
      "type": "command",
      "server": "healthmon",
      "application": "system",
      "command": "df -h / | tail -1 | awk '{print $5}' | sed 's/%//'",
      "expectedContains": "",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "system", "disk"]
    },
    {
      "id": "dns-check",
      "name": "DNS Resolution",
      "type": "command",
      "server": "healthmon",
      "application": "network",
      "command": "nslookup google.com > /dev/null 2>&1 && echo 'DNS OK'",
      "expectedContains": "DNS OK",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "network"]
    },
    {
      "id": "app-log",
      "name": "Application Log",
      "type": "log",
      "server": "healthmon",
      "application": "healthops",
      "path": "/app/data/healthmon.log",
      "freshnessSeconds": 120,
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["logs", "self"]
    }
  ]
}
