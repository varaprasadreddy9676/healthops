{
  "server": {
    "addr": ":8080",
    "readTimeoutSeconds": 10,
    "writeTimeoutSeconds": 10,
    "idleTimeoutSeconds": 60
  },
  "retentionDays": 7,
  "checkIntervalSeconds": 30,
  "workers": 8,
  "allowCommandChecks": true,
  "checks": [
    {
      "id": "self-health",
      "name": "HealthOps API",
      "type": "api",
      "server": "healthops",
      "application": "healthops",
      "target": "http://localhost:8080/healthz",
      "expectedStatus": 200,
      "expectedContains": "ok",
      "timeoutSeconds": 5,
      "warningThresholdMs": 500,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["api", "self", "critical"]
    },
    {
      "id": "healthops-process",
      "name": "HealthOps Process",
      "type": "process",
      "server": "healthops",
      "application": "healthops",
      "target": "healthops",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "self"]
    },
    {
      "id": "disk-space",
      "name": "Disk Space Check",
      "type": "command",
      "server": "healthops",
      "application": "system",
      "command": "df -h / | tail -1 | awk '{print $5}' | sed 's/%//'",
      "expectedContains": "",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "system", "disk"]
    },
    {
      "id": "dns-check",
      "name": "DNS Resolution",
      "type": "command",
      "server": "healthops",
      "application": "network",
      "command": "nslookup google.com > /dev/null 2>&1 && echo 'DNS OK'",
      "expectedContains": "DNS OK",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "network"]
    }
  ]
}
