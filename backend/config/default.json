{
  "server": {
    "addr": ":8080",
    "readTimeoutSeconds": 10,
    "writeTimeoutSeconds": 10,
    "idleTimeoutSeconds": 60
  },
  "retentionDays": 7,
  "checkIntervalSeconds": 30,
  "workers": 8,
  "allowCommandChecks": true,
  "servers": [],
  "checks": [
    {
      "id": "self-health",
      "name": "HealthOps API",
      "type": "api",
      "server": "healthops",
      "application": "healthops",
      "target": "http://localhost:8080/healthz",
      "expectedStatus": 200,
      "expectedContains": "ok",
      "timeoutSeconds": 5,
      "warningThresholdMs": 500,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["api", "self", "critical"]
    }
  ]
}
