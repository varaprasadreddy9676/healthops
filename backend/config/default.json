{
  "server": {
    "addr": ":8080",
    "readTimeoutSeconds": 10,
    "writeTimeoutSeconds": 10,
    "idleTimeoutSeconds": 60
  },
  "retentionDays": 7,
  "checkIntervalSeconds": 30,
  "workers": 8,
  "allowCommandChecks": true,
  "servers": [
    {
      "id": "docker-linux-1",
      "name": "Docker Test Linux 1",
      "host": "localhost",
      "port": 2222,
      "user": "root",
      "password": "testpass123",
      "tags": ["linux", "docker", "test"]
    },
    {
      "id": "docker-linux-2",
      "name": "Docker Test Linux 2",
      "host": "localhost",
      "port": 2223,
      "user": "root",
      "password": "testpass123",
      "tags": ["linux", "docker", "test"]
    }
  ],
  "checks": [
    {
      "id": "self-health",
      "name": "HealthOps API",
      "type": "api",
      "server": "healthops",
      "application": "healthops",
      "target": "http://localhost:8080/healthz",
      "expectedStatus": 200,
      "expectedContains": "ok",
      "timeoutSeconds": 5,
      "warningThresholdMs": 500,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["api", "self", "critical"]
    },
    {
      "id": "healthops-process",
      "name": "HealthOps Process",
      "type": "process",
      "server": "healthops",
      "application": "healthops",
      "target": "healthops",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "self"]
    },
    {
      "id": "disk-space",
      "name": "Disk Space Check",
      "type": "command",
      "server": "healthops",
      "application": "system",
      "command": "df -h / | tail -1 | awk '{print $5}' | sed 's/%//'",
      "expectedContains": "",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "system", "disk"]
    },
    {
      "id": "dns-check",
      "name": "DNS Resolution",
      "type": "command",
      "server": "healthops",
      "application": "network",
      "command": "nslookup google.com > /dev/null 2>&1 && echo 'DNS OK'",
      "expectedContains": "DNS OK",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "network"]
    },
    {
      "id": "mysql-health",
      "name": "MySQL Database Health",
      "type": "mysql",
      "server": "docker-mysql",
      "application": "mysql",
      "timeoutSeconds": 10,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["mysql", "database"],
      "mysql": {
        "host": "127.0.0.1",
        "port": 3306,
        "username": "healthops",
        "password": "healthops123",
        "database": "healthops",
        "connectTimeoutSeconds": 3,
        "queryTimeoutSeconds": 5,
        "processlistLimit": 50,
        "statementLimit": 20,
        "hostUserLimit": 20
      }
    },
    {
      "id": "ssh-docker-test-linux-1",
      "name": "Docker Test Linux 1",
      "type": "ssh",
      "server": "docker-test-linux-1",
      "application": "linux",
      "timeoutSeconds": 10,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["ssh", "linux", "docker"],
      "ssh": {
        "host": "localhost",
        "port": 2222,
        "user": "root",
        "password": "testpass123"
      }
    },
    {
      "id": "ssh-docker-test-linux-2",
      "name": "Docker Test Linux 2",
      "type": "ssh",
      "server": "docker-test-linux-2",
      "application": "linux",
      "timeoutSeconds": 10,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["ssh", "linux", "docker"],
      "ssh": {
        "host": "localhost",
        "port": 2223,
        "user": "root",
        "password": "testpass123"
      }
    },
    {
      "id": "nginx-linux-1",
      "name": "Nginx on Linux 1",
      "type": "process",
      "server": "docker-linux-1",
      "application": "nginx",
      "target": "nginx",
      "serverId": "docker-linux-1",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "nginx", "docker"]
    },
    {
      "id": "python-http-linux-1",
      "name": "Python HTTP Server on Linux 1",
      "type": "process",
      "server": "docker-linux-1",
      "application": "python",
      "target": "http.server",
      "serverId": "docker-linux-1",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "python", "docker"]
    },
    {
      "id": "cron-linux-1",
      "name": "Cron Daemon on Linux 1",
      "type": "process",
      "server": "docker-linux-1",
      "application": "system",
      "target": "cron",
      "serverId": "docker-linux-1",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "cron", "docker"]
    },
    {
      "id": "nginx-linux-2",
      "name": "Nginx on Linux 2",
      "type": "process",
      "server": "docker-linux-2",
      "application": "nginx",
      "target": "nginx",
      "serverId": "docker-linux-2",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "nginx", "docker"]
    },
    {
      "id": "python-http-linux-2",
      "name": "Python HTTP Server on Linux 2",
      "type": "process",
      "server": "docker-linux-2",
      "application": "python",
      "target": "http.server",
      "serverId": "docker-linux-2",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "python", "docker"]
    }
  ]
}
