{
  "server": {
    "addr": ":8080",
    "readTimeoutSeconds": 10,
    "writeTimeoutSeconds": 10,
    "idleTimeoutSeconds": 60
  },
  "retentionDays": 7,
  "checkIntervalSeconds": 30,
  "workers": 8,
  "allowCommandChecks": true,
  "checks": [
    {
      "id": "self-health",
      "name": "HealthOps API",
      "type": "api",
      "server": "healthops",
      "application": "healthops",
      "target": "http://localhost:8080/healthz",
      "expectedStatus": 200,
      "expectedContains": "ok",
      "timeoutSeconds": 5,
      "warningThresholdMs": 500,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["api", "self", "critical"]
    },
    {
      "id": "mongo-tcp",
      "name": "MongoDB Connection",
      "type": "tcp",
      "server": "healthops",
      "application": "mongodb",
      "host": "mongo",
      "port": 27017,
      "timeoutSeconds": 5,
      "warningThresholdMs": 200,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["tcp", "database", "critical"]
    },
    {
      "id": "nginx-health",
      "name": "Nginx Health Endpoint",
      "type": "api",
      "server": "demo",
      "application": "nginx",
      "target": "http://nginx:80/health",
      "expectedStatus": 200,
      "expectedContains": "ok",
      "timeoutSeconds": 5,
      "warningThresholdMs": 200,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["api", "webserver", "demo"]
    },
    {
      "id": "nginx-homepage",
      "name": "Nginx Homepage",
      "type": "api",
      "server": "demo",
      "application": "nginx",
      "target": "http://nginx:80/",
      "expectedStatus": 200,
      "expectedContains": "Demo App",
      "timeoutSeconds": 5,
      "warningThresholdMs": 300,
      "intervalSeconds": 60,
      "retryCount": 1,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 60,
      "enabled": true,
      "tags": ["api", "webserver", "demo"]
    },
    {
      "id": "nginx-tcp",
      "name": "Nginx Port 80",
      "type": "tcp",
      "server": "demo",
      "application": "nginx",
      "host": "nginx",
      "port": 80,
      "timeoutSeconds": 5,
      "warningThresholdMs": 100,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["tcp", "webserver", "demo"]
    },
    {
      "id": "redis-tcp",
      "name": "Redis Connection",
      "type": "tcp",
      "server": "demo",
      "application": "redis",
      "host": "redis",
      "port": 6379,
      "timeoutSeconds": 5,
      "warningThresholdMs": 100,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["tcp", "cache", "demo"]
    },
    {
      "id": "echo-api",
      "name": "Echo Server API",
      "type": "api",
      "server": "demo",
      "application": "echo",
      "target": "http://echo-server:9000/",
      "expectedStatus": 200,
      "expectedContains": "healthy",
      "timeoutSeconds": 5,
      "warningThresholdMs": 200,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["api", "demo"]
    },
    {
      "id": "mysql-tcp",
      "name": "MySQL Connection",
      "type": "tcp",
      "server": "demo",
      "application": "mysql",
      "host": "mysql",
      "port": 3306,
      "timeoutSeconds": 5,
      "warningThresholdMs": 200,
      "intervalSeconds": 30,
      "retryCount": 2,
      "retryDelaySeconds": 3,
      "cooldownSeconds": 30,
      "enabled": true,
      "tags": ["tcp", "database", "demo"]
    },
    {
      "id": "mysql-health",
      "name": "MySQL Database Health",
      "type": "mysql",
      "server": "demo",
      "application": "mysql",
      "timeoutSeconds": 10,
      "intervalSeconds": 30,
      "retryCount": 1,
      "retryDelaySeconds": 5,
      "cooldownSeconds": 60,
      "enabled": true,
      "tags": ["mysql", "database", "critical", "demo"],
      "mysql": {
        "dsnEnv": "MYSQL_DSN",
        "connectTimeoutSeconds": 3,
        "queryTimeoutSeconds": 5,
        "processlistLimit": 50,
        "statementLimit": 20,
        "hostUserLimit": 20
      }
    },
    {
      "id": "healthops-process",
      "name": "HealthOps Process",
      "type": "process",
      "server": "healthops",
      "application": "healthops",
      "target": "healthops",
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["process", "self"]
    },
    {
      "id": "disk-space",
      "name": "Disk Space Check",
      "type": "command",
      "server": "healthops",
      "application": "system",
      "command": "df -h / | tail -1 | awk '{print $5}' | sed 's/%//'",
      "expectedContains": "",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "system", "disk"]
    },
    {
      "id": "dns-check",
      "name": "DNS Resolution",
      "type": "command",
      "server": "healthops",
      "application": "network",
      "command": "nslookup google.com > /dev/null 2>&1 && echo 'DNS OK'",
      "expectedContains": "DNS OK",
      "timeoutSeconds": 5,
      "intervalSeconds": 60,
      "enabled": true,
      "tags": ["command", "network"]
    },
    {
      "id": "app-log",
      "name": "Application Log",
      "type": "log",
      "server": "healthops",
      "application": "healthops",
      "path": "/app/data/healthops.log",
      "freshnessSeconds": 120,
      "timeoutSeconds": 5,
      "intervalSeconds": 30,
      "enabled": true,
      "tags": ["logs", "self"]
    }
  ]
}
